---
export const prerender = false;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>icart — Gadgets for everyday life</title>
  <meta name="description" content="Phones, laptops, cameras, and more — the tech you actually use, all in one shop." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --blue: #174EA6;
      --blue-dark: #123C82;
      --red: #A50E0E;
      --red-dark: #850B0B;
      --white: #FFFFFF;
      --ink: #0B1220;
      --slate: #5B6472;
      --tint: #EEF3FC;
      --line: #D8E1F0;

      --font-display: 'Space Grotesk', sans-serif;
      --font-body: 'IBM Plex Sans', sans-serif;
      --font-mono: 'IBM Plex Mono', monospace;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; overflow-x: hidden; }
    body {
      font-family: var(--font-body);
      color: var(--ink);
      background: var(--white);
      line-height: 1.5;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    img, svg { display: block; max-width: 100%; }
    a { color: inherit; }

    .wrap {
      max-width: 1180px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* ---------- Header ---------- */
    header.site-header {
      position: sticky;
      top: 0;
      z-index: 20;
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--line);
    }
    .header-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      row-gap: 0.5rem;
      padding: 1.1rem 0;
    }
    .logo {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.4rem;
      letter-spacing: -0.02em;
      text-decoration: none;
      color: var(--ink);
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .logo .dot { color: var(--red); }
    nav.header-actions {
      display: flex;
      align-items: center;
      gap: 1.1rem;
    }
    .link-admin {
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--slate);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color 0.15s ease, color 0.15s ease;
    }
    .link-admin:hover { color: var(--ink); border-color: var(--slate); }
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-body);
      font-weight: 600;
      font-size: 0.9rem;
      text-decoration: none;
      border-radius: 8px;
      padding: 0.55rem 1.15rem;
      border: 1.5px solid transparent;
      cursor: pointer;
      transition: transform 0.12s ease, background 0.15s ease, border-color 0.15s ease;
    }
    .btn:active { transform: translateY(1px); }
    .btn-primary { background: var(--blue); color: var(--white); }
    .btn-primary:hover { background: var(--blue-dark); }
    .btn-outline { background: transparent; color: var(--blue); border-color: var(--blue); }
    .btn-outline:hover { background: var(--tint); }
    .btn-red { background: var(--red); color: var(--white); }
    .btn-red:hover { background: var(--red-dark); }

    /* ---------- Hero ---------- */
    .hero {
      padding: clamp(3rem, 6vw, 6rem) 0 clamp(2.5rem, 5vw, 4rem);
    }
    .hero-grid {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: clamp(2rem, 5vw, 4rem);
      align-items: center;
    }
    .eyebrow {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--red);
      margin-bottom: 1rem;
      display: inline-block;
    }
    .hero h1 {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: clamp(2.2rem, 5vw, 3.4rem);
      line-height: 1.06;
      letter-spacing: -0.02em;
      color: var(--ink);
      margin-bottom: 1.1rem;
    }
    .hero h1 .accent { color: var(--blue); }
    .hero p.lede {
      font-size: clamp(1rem, 1.6vw, 1.15rem);
      color: var(--slate);
      max-width: 42ch;
      margin-bottom: 1.75rem;
    }
    .hero-ctas {
      display: flex;
      gap: 0.9rem;
      flex-wrap: wrap;
    }
    .hero-ctas .btn { padding: 0.75rem 1.5rem; font-size: 0.95rem; }

    /* Hero illustration collage */
    .hero-art {
      position: relative;
      aspect-ratio: 1 / 0.85;
      display: grid;
      place-items: center;
    }
    .art-card {
      position: absolute;
      background: var(--tint);
      border: 1px solid var(--line);
      border-radius: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .art-card.c1 { width: 62%; height: 62%; top: 0; left: 4%; }
    .art-card.c2 { width: 46%; height: 46%; bottom: 2%; right: 0; background: var(--white); border-color: var(--blue); }
    .art-card.c3 { width: 34%; height: 34%; top: 6%; right: 6%; background: var(--ink); }
    .art-card svg { width: 55%; height: 55%; }
    .art-card.c1 svg { color: var(--blue); }
    .art-card.c2 svg { color: var(--red); }
    .art-card.c3 svg { color: var(--white); }

    /* ---------- Ticker ---------- */
    .ticker-band {
      background: var(--ink);
      color: var(--white);
      overflow: hidden;
      white-space: nowrap;
      padding: 0.85rem 0;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
    .ticker-track {
      display: inline-flex;
      gap: 2.5rem;
      animation: scroll-ticker 28s linear infinite;
      font-family: var(--font-mono);
      font-size: 0.85rem;
      font-weight: 500;
      letter-spacing: 0.02em;
    }
    .ticker-track span.sep { color: var(--red); padding: 0 0.25rem; }
    @keyframes scroll-ticker {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }
    @media (prefers-reduced-motion: reduce) {
      .ticker-track { animation: none; }
    }

    /* ---------- Featured gear ---------- */
    .section { padding: clamp(3rem, 6vw, 5rem) 0; }
    .section-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      margin-bottom: 2rem;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .section-head h2 {
      font-family: var(--font-display);
      font-size: clamp(1.5rem, 3vw, 2rem);
      font-weight: 700;
      letter-spacing: -0.01em;
    }
    .section-head p { color: var(--slate); font-size: 0.95rem; max-width: 40ch; }

    .gear-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.25rem;
    }
    .gear-card {
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 1.5rem 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
      transition: border-color 0.15s ease, transform 0.15s ease;
    }
    .gear-card:hover { border-color: var(--blue); transform: translateY(-3px); }
    .gear-icon {
      width: 100%;
      aspect-ratio: 1.3 / 1;
      background: var(--tint);
      border-radius: 10px;
      display: grid;
      place-items: center;
    }
    .gear-icon svg { width: 42%; height: 42%; color: var(--blue); }
    .gear-card h3 {
      font-family: var(--font-display);
      font-size: 1.02rem;
      font-weight: 600;
    }
    .gear-card p.spec {
      font-family: var(--font-mono);
      font-size: 0.85rem;
      color: var(--slate);
    }
    .gear-card .price {
      font-family: var(--font-mono);
      font-weight: 600;
      color: var(--red);
      font-size: 1rem;
    }

    /* ---------- Trust strip ---------- */
    .trust-band { background: var(--tint); }
    .trust-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
    .trust-item { display: flex; gap: 0.85rem; align-items: flex-start; }
    .trust-item svg { width: 26px; height: 26px; flex-shrink: 0; color: var(--blue); margin-top: 0.15rem; }
    .trust-item h4 { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.2rem; }
    .trust-item p { font-size: 0.85rem; color: var(--slate); }

    /* ---------- CTA band ---------- */
    .cta-band {
      background: var(--red);
      color: var(--white);
      text-align: center;
      padding: clamp(2.5rem, 5vw, 4rem) 0;
    }
    .cta-band h2 {
      font-family: var(--font-display);
      font-size: clamp(1.6rem, 3.5vw, 2.3rem);
      font-weight: 700;
      margin-bottom: 0.75rem;
      letter-spacing: -0.01em;
    }
    .cta-band p { opacity: 0.9; margin-bottom: 1.75rem; }
    .cta-band .btn-primary { background: var(--white); color: var(--red); }
    .cta-band .btn-primary:hover { background: var(--tint); }

    /* ---------- Footer ---------- */
    footer {
      padding: 2.5rem 0;
      border-top: 1px solid var(--line);
    }
    .footer-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .footer-links { display: flex; gap: 1.5rem; }
    .footer-links a { font-size: 0.85rem; color: var(--slate); text-decoration: none; }
    .footer-links a:hover { color: var(--ink); }
    .footer-copy { font-size: 0.8rem; color: var(--slate); }

    /* ---------- Responsive ---------- */
    @media (max-width: 900px) {
      .hero-grid { grid-template-columns: 1fr; }
      .hero-art { max-width: 420px; margin: 0 auto; order: -1; }
      .gear-grid { grid-template-columns: repeat(2, 1fr); }
      .trust-grid { grid-template-columns: repeat(2, 1fr); }
      .header-row { padding-left: 0.75rem; padding-right: 0.75rem; }
    }
    @media (max-width: 560px) {
      .header-row { padding: 0.9rem 0.5rem; }
      .logo { font-size: 1.2rem; }
      nav.header-actions { gap: 0.6rem; }
      .link-admin { font-size: 0.78rem; }
      .btn { padding: 0.5rem 0.9rem; font-size: 0.82rem; }
      .hero-ctas .btn { padding: 0.65rem 1.1rem; font-size: 0.88rem; }
      .gear-grid { grid-template-columns: 1fr 1fr; gap: 0.85rem; }
      .gear-card { padding: 1rem 0.9rem; }
      .trust-grid { grid-template-columns: 1fr; }
      .footer-row { flex-direction: column; align-items: flex-start; }
      .ticker-track { font-size: 0.75rem; gap: 1.75rem; }
    }
    @media (max-width: 400px) {
      .gear-grid { grid-template-columns: 1fr; }
      .hero-art { max-width: 300px; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="wrap header-row">
      <a class="logo" href="/">icart<span class="dot">.</span></a>
      <nav class="header-actions">
        <a class="link-admin" href="/admin/login">Admin</a>
        <a class="btn btn-primary" href="/shop/login">Sign in</a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="wrap hero-grid">
        <div class="hero-copy">
          <span class="eyebrow">Tech for everyday life</span>
          <h1>Gadgets built<br />around <span class="accent">you</span>.</h1>
          <p class="lede">Phones, laptops, cameras, and the everyday tech in between — picked for people who live on their devices.</p>
          <div class="hero-ctas">
            <a class="btn btn-primary" href="/shop/signup">Shop the gadgets</a>
            <a class="btn btn-outline" href="/shop/login">Sign in</a>
          </div>
        </div>
        <div class="hero-art" aria-hidden="true">
          <div class="art-card c1">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
              <!-- laptop -->
              <rect x="4" y="4" width="16" height="10" rx="1"/>
              <path d="M2 18h20l-1.5-3h-17z"/>
            </svg>
          </div>
          <div class="art-card c2">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
              <!-- smartphone -->
              <rect x="7" y="2" width="10" height="20" rx="2"/>
              <path d="M11 18h2"/>
            </svg>
          </div>
          <div class="art-card c3">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
              <!-- camera -->
              <path d="M4 8h3l2-2h6l2 2h3a1 1 0 011 1v10a1 1 0 01-1 1H4a1 1 0 01-1-1V9a1 1 0 011-1z"/>
              <circle cx="12" cy="13" r="3.5"/>
            </svg>
          </div>
        </div>
      </div>
    </section>

    <!-- Ticker -->
    <div class="ticker-band" role="marquee" aria-label="Featured product specs">
      <div class="ticker-track">
        <span>SMARTPHONE <span class="sep">·</span> $699.00 <span class="sep">·</span> 5G <span class="sep">·</span> IN STOCK</span>
        <span>LAPTOP <span class="sep">·</span> $1,299.00 <span class="sep">·</span> 16GB RAM <span class="sep">·</span> IN STOCK</span>
        <span>CAMERA <span class="sep">·</span> $549.00 <span class="sep">·</span> 24MP <span class="sep">·</span> IN STOCK</span>
        <span>SMARTWATCH <span class="sep">·</span> $249.00 <span class="sep">·</span> GPS <span class="sep">·</span> LOW STOCK</span>
        <!-- duplicate for seamless loop -->
        <span>SMARTPHONE <span class="sep">·</span> $699.00 <span class="sep">·</span> 5G <span class="sep">·</span> IN STOCK</span>
        <span>LAPTOP <span class="sep">·</span> $1,299.00 <span class="sep">·</span> 16GB RAM <span class="sep">·</span> IN STOCK</span>
        <span>CAMERA <span class="sep">·</span> $549.00 <span class="sep">·</span> 24MP <span class="sep">·</span> IN STOCK</span>
        <span>SMARTWATCH <span class="sep">·</span> $249.00 <span class="sep">·</span> GPS <span class="sep">·</span> LOW STOCK</span>
      </div>
    </div>

    <!-- Featured gear -->
    <section class="section">
      <div class="wrap">
        <div class="section-head">
          <h2>Featured gadgets</h2>
          <p>A preview of what's in the shop right now — sign in to see the full catalog.</p>
        </div>
        <div class="gear-grid">
          <div class="gear-card">
            <div class="gear-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <rect x="7" y="2" width="10" height="20" rx="2"/><path d="M11 18h2"/>
              </svg>
            </div>
            <h3>Smartphone</h3>
            <p class="spec">5G · 128GB</p>
            <span class="price">$699.00</span>
          </div>
          <div class="gear-card">
            <div class="gear-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <rect x="4" y="4" width="16" height="10" rx="1"/><path d="M2 18h20l-1.5-3h-17z"/>
              </svg>
            </div>
            <h3>Laptop</h3>
            <p class="spec">16GB RAM · 512GB SSD</p>
            <span class="price">$1,299.00</span>
          </div>
          <div class="gear-card">
            <div class="gear-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 8h3l2-2h6l2 2h3a1 1 0 011 1v10a1 1 0 01-1 1H4a1 1 0 01-1-1V9a1 1 0 011-1z"/><circle cx="12" cy="13" r="3.5"/>
              </svg>
            </div>
            <h3>Camera</h3>
            <p class="spec">24MP · 4K Video</p>
            <span class="price">$549.00</span>
          </div>
          <div class="gear-card">
            <div class="gear-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <rect x="7" y="6" width="10" height="12" rx="2"/><path d="M9 6V4h6v2M9 18v2h6v-2"/>
              </svg>
            </div>
            <h3>Smartwatch</h3>
            <p class="spec">GPS · Always-on display</p>
            <span class="price">$249.00</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust strip -->
    <section class="section trust-band">
      <div class="wrap trust-grid">
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          <div><h4>Fast dispatch</h4><p>Ships within 24 hours.</p></div>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l8 4v6c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-4z"/></svg>
          <div><h4>Secure checkout</h4><p>Encrypted, always.</p></div>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
          <div><h4>Genuine tech</h4><p>No knockoffs, ever.</p></div>
        </div>
        <div class="trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <div><h4>Real support</h4><p>Humans, not bots.</p></div>
        </div>
      </div>
    </section>

    <!-- CTA band -->
    <section class="cta-band">
      <div class="wrap">
        <h2>Your next gadget is one click away.</h2>
        <p>Create an account and start shopping.</p>
        <a class="btn btn-primary" href="/shop/signup">Create an account</a>
      </div>
    </section>
  </main>

  <footer>
    <div class="wrap footer-row">
      <a class="logo" href="/" style="font-size:1.1rem;">icart<span class="dot">.</span></a>
      <div class="footer-links">
        <a href="/shop/products">Shop</a>
        <a href="/shop/login">Sign in</a>
        <a href="/admin/login">Admin</a>
      </div>
      <p class="footer-copy">© 2026 icart. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>