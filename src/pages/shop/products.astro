---
export const prerender = false;
const userName = await Astro.session?.get('userName');
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Products · icart</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
  <style is:global>
    :root {
      --blue: #174EA6;
      --blue-dark: #123C82;
      --red: #A50E0E;
      --white: #FFFFFF;
      --ink: #0B1220;
      --slate: #5B6472;
      --tint: #EEF3FC;
      --line: #D8E1F0;
      --font-display: 'Space Grotesk', sans-serif;
      --font-body: 'IBM Plex Sans', sans-serif;
      --font-mono: 'IBM Plex Mono', monospace;
      --radius: 14px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: var(--font-body);
      background: var(--tint);
      color: var(--ink);
    }
    img, svg { display: block; max-width: 100%; }

    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.6rem;
      padding: 1.1rem 1.5rem;
      background: var(--white);
      border-bottom: 1px solid var(--line);
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .logo {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.25rem;
      letter-spacing: -0.02em;
      text-decoration: none;
      color: var(--ink);
    }
    .logo .dot { color: var(--red); }
    header .right { display: flex; align-items: center; gap: 1rem; font-size: 0.9rem; color: var(--slate); }
    a.cart-link {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      text-decoration: none;
      color: var(--blue);
      font-weight: 600;
      font-size: 0.88rem;
      border: 1px solid var(--blue);
      border-radius: 999px;
      padding: 0.35rem 0.9rem;
      transition: background 0.15s ease;
    }
    a.cart-link:hover { background: var(--tint); }
    button.logout-btn {
      cursor: pointer;
      background: transparent;
      color: var(--red);
      border: 1px solid var(--red);
      border-radius: 8px;
      padding: 0.4rem 0.85rem;
      font-size: 0.83rem;
      font-weight: 600;
      font-family: var(--font-body);
      transition: background 0.15s ease, color 0.15s ease;
    }
    button.logout-btn:hover { background: var(--red); color: var(--white); }

    main { max-width: 1280px; margin: 0 auto; padding: 2rem 1.5rem 3.5rem; }

    #toast-container {
      position: fixed;
      bottom: 1.25rem;
      right: 1.25rem;
      left: auto;
      display: flex;
      flex-direction: column-reverse;
      gap: 0.6rem;
      z-index: 50;
      max-width: calc(100% - 2.5rem);
    }
    .toast {
      background: var(--ink);
      color: var(--white);
      padding: 0.7rem 1rem;
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 500;
      box-shadow: 0 10px 28px rgba(11, 18, 32, 0.2);
      max-width: 300px;
      opacity: 0;
      transform: translateY(8px);
      transition: opacity 0.2s ease, transform 0.2s ease;
    }
    .toast.show { opacity: 1; transform: translateY(0); }
    .toast.success { background: #146c3c; }
    .toast.error { background: var(--red); }

    /* ---------- Product grid ---------- */
    .product-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
      gap: 2.5rem 2rem;
      align-items: stretch;
    }
    .product-card {
      background: var(--white);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      box-shadow: 0 1px 2px rgba(11, 18, 32, 0.04);
      transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
    }
    .product-card:hover {
      border-color: var(--blue);
      transform: translateY(-3px);
      box-shadow: 0 12px 28px rgba(11, 18, 32, 0.1);
    }
    .product-thumb {
      position: relative;
      width: 100%;
      height: 170px;
      flex-shrink: 0;
      background: var(--tint);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      border-bottom: 1px solid var(--line);
    }
    .product-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .product-thumb svg { width: 30%; height: 30%; color: var(--blue); opacity: 0.5; }

    .stock-line {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--slate);
      display: block;
    }
    .stock-line.low,
    .stock-line.out { color: var(--red); }

    .product-body {
      padding: 1rem 1.1rem 1.1rem;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      flex: 1;
    }
    .product-body h3 {
      font-family: var(--font-display);
      font-size: 1rem;
      font-weight: 600;
      line-height: 1.3;
    }
    .product-body p.desc {
      font-size: 0.83rem;
      color: var(--slate);
      line-height: 1.45;
      flex-grow: 1;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .product-price {
      font-family: var(--font-mono);
      font-size: 1.05rem;
      font-weight: 600;
      color: var(--red);
      border-top: 1px solid var(--line);
      padding-top: 0.65rem;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
    }

    button.add-btn {
      cursor: pointer;
      border: none;
      border-radius: 8px;
      padding: 0.6rem;
      margin-top: 0.3rem;
      font-family: var(--font-body);
      font-size: 0.88rem;
      font-weight: 600;
      background: var(--blue);
      color: var(--white);
      transition: background 0.15s ease;
    }
    button.add-btn:hover { background: var(--blue-dark); }
    button.add-btn:disabled { background: var(--line); color: var(--slate); cursor: not-allowed; }
    button.add-btn.in-cart {
      background: var(--tint);
      color: var(--blue);
      border: 1.5px solid var(--blue);
    }
    button.add-btn.in-cart:hover { background: #dde9fa; }

    #empty-state {
      text-align: center;
      padding: 3.5rem 1.5rem;
      color: var(--slate);
      background: var(--white);
      border: 1px dashed var(--line);
      border-radius: var(--radius);
    }

    /* ---------- Tablet ---------- */
    @media (max-width: 900px) {
      main { padding: 1.75rem 1.25rem 3rem; }
      .product-grid { grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 2rem 1.25rem; }
    }

    /* ---------- Mobile (large) ---------- */
    @media (max-width: 640px) {
      header { padding: 0.9rem 1rem; }
      header .right { gap: 0.6rem; }
      header .right span { display: none; }

      main { padding: 1.5rem 1rem 2.75rem; }

      .product-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 1.5rem 0.9rem; }
      .product-body { padding: 0.8rem 0.85rem 0.9rem; gap: 0.5rem; }
    }

    /* ---------- Mobile (small) ---------- */
    @media (max-width: 480px) {
      .product-grid { grid-template-columns: 1fr 1fr; gap: 1.1rem 0.7rem; }
      .product-thumb { height: 130px; }
      .product-body h3 { font-size: 0.9rem; }
      .product-price { font-size: 0.92rem; }
    }

    @media (max-width: 360px) {
      .product-grid { grid-template-columns: 1fr; }
      .product-thumb { height: 190px; }
    }
  </style>
</head>
<body>
  <header>
    <a class="logo" href="/">icart<span class="dot">.</span></a>
    <div class="right">
      <span>Hi, {userName}</span>
      <a class="cart-link" href="/shop/cart">🛒 Cart</a>
      <button class="logout-btn" id="logout-btn">Log out</button>
    </div>
  </header>

  <main>
    <div id="product-grid" class="product-grid"></div>
    <div id="empty-state" hidden>No products available right now.</div>
  </main>

  <div id="toast-container"></div>

  <script>
    // Trusted, static SVG string only -- never built from user data, so innerHTML is safe here.
    const PLACEHOLDER_SVG = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"></rect><circle cx="9" cy="9" r="2"></circle><path d="M21 15l-5-5L5 21"></path></svg>';

    function showToast(message, type) {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      toast.className = 'toast ' + type;
      toast.textContent = message;
      container.appendChild(toast);

      // Two rAFs so the browser registers the initial (pre-.show) state before transitioning.
      requestAnimationFrame(() => requestAnimationFrame(() => toast.classList.add('show')));

      setTimeout(() => {
        toast.classList.remove('show');
        toast.addEventListener('transitionend', () => toast.remove(), { once: true });
      }, 2400);
    }

    function buildThumb(product) {
      const thumb = document.createElement('div');
      thumb.className = 'product-thumb';
      if (product.imageUrl) {
        const img = document.createElement('img');
        img.src = product.imageUrl;
        img.alt = product.name;
        img.addEventListener('error', () => { thumb.innerHTML = PLACEHOLDER_SVG; }, { once: true });
        thumb.appendChild(img);
      } else {
        thumb.innerHTML = PLACEHOLDER_SVG;
      }
      return thumb;
    }

    function buildStockLine(stock) {
      const line = document.createElement('span');
      let state = '';
      let text = stock + ' in stock';
      if (stock <= 0) {
        state = 'out';
        text = 'Out of stock';
      } else if (stock <= 5) {
        state = 'low';
        text = 'Only ' + stock + ' left';
      }
      line.className = 'stock-line' + (state ? ' ' + state : '');
      line.textContent = text;
      return line;
    }

    function buildProductCard(p, cartProductIds) {
      const card = document.createElement('div');
      card.className = 'product-card';
      card.appendChild(buildThumb(p));

      const body = document.createElement('div');
      body.className = 'product-body';

      const h3 = document.createElement('h3');
      h3.textContent = p.name;
      body.appendChild(h3);

      const desc = document.createElement('p');
      desc.className = 'desc';
      desc.textContent = p.description || '';
      body.appendChild(desc);

      const price = document.createElement('div');
      price.className = 'product-price';
      const priceAmount = document.createElement('span');
      priceAmount.textContent = '$' + p.price.toFixed(2);
      price.appendChild(priceAmount);
      price.appendChild(buildStockLine(p.stock));
      body.appendChild(price);

      const isInCart = cartProductIds.has(p.id);
      const addBtn = document.createElement('button');
      addBtn.className = 'add-btn' + (isInCart ? ' in-cart' : '');
      addBtn.textContent = p.stock <= 0 ? 'Out of stock' : (isInCart ? '✓ Added to Cart' : 'Add to cart');
      addBtn.disabled = p.stock <= 0;
      addBtn.addEventListener('click', () => addToCart(p.id, addBtn));
      body.appendChild(addBtn);

      card.appendChild(body);
      return card;
    }

    async function loadProducts() {
      const [productsRes, cartRes] = await Promise.all([
        fetch('/api/products'),
        fetch('/api/cart')
      ]);
      const products = await productsRes.json();
      const cart = await cartRes.json();
      const cartProductIds = new Set(cart.items.map((item) => item.productId));
      renderProducts(products, cartProductIds);
    }

    function renderProducts(products, cartProductIds) {
      const grid = document.getElementById('product-grid');
      const emptyState = document.getElementById('empty-state');
      grid.innerHTML = '';
      emptyState.hidden = products.length > 0;

      for (const p of products) {
        grid.appendChild(buildProductCard(p, cartProductIds));
      }
    }

    async function addToCart(productId, btn) {
      btn.disabled = true;
      const originalText = btn.textContent;
      btn.textContent = 'Adding…';

      try {
        const res = await fetch('/api/cart/items', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ productId, quantity: 1 })
        });
        const data = await res.json();

        if (!res.ok) {
          showToast(data.message || 'Could not add item to cart.', 'error');
          btn.disabled = false;
          btn.textContent = originalText;
          return;
        }

        showToast('Added to cart.', 'success');
        await loadProducts();
      } catch (err) {
        showToast('Something went wrong. Please try again.', 'error');
        btn.disabled = false;
        btn.textContent = originalText;
      }
    }

    document.getElementById('logout-btn').addEventListener('click', async () => {
      await fetch('/api/shop/auth/logout', { method: 'POST' });
      window.location.href = '/shop/login';
    });

    loadProducts();
  </script>
</body>
</html>